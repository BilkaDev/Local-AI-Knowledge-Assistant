# Runtime
APP_PORT=8501
APP_ENV=development

# Model and AI stack
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# Retrieval defaults
CHROMA_HOST=chroma
CHROMA_PORT=8000
TOP_K=4

# Data locations in container
DATA_DIR=/workspace/data
CHROMA_PERSIST_DIR=/workspace/artifacts/chroma
