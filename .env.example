# Runtime
APP_PORT=8501
APP_ENV=development

# Model and AI stack
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2:1b
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_INIT_MODELS=nomic-embed-text llama3.2:1b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=64

# Retrieval defaults
CHROMA_HOST=chroma
CHROMA_PORT=8000
TOP_K=1
RETRIEVAL_TOP_K=1
RETRIEVAL_MAX_DISTANCE=0.85
CHROMA_COLLECTION_NAME=rag_chunks
EMBEDDING_BATCH_SIZE=32
CHUNK_SIZE=900
CHUNK_OVERLAP=150
INGEST_REPORT_PATH=/workspace/artifacts/ingest/latest.json
INDEX_REPORT_PATH=/workspace/artifacts/index/latest.json

# Data locations in container
DATA_DIR=/workspace/data
CHROMA_PERSIST_DIR=/workspace/artifacts/chroma
